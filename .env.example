# ===== ZhiPath 环境变量样例 =====
# 复制为 .env 后填写真实值；.env 不得入库

APP_ENV=local

# ---------- MySQL ----------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=consult
MYSQL_PASSWORD=consult
MYSQL_DATABASE=zhipath
DATABASE_URL=consult:consult@tcp(localhost:3306)/zhipath?parseTime=true&loc=Local

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ---------- Qdrant ----------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_KB=zhipath_kb_v1
QDRANT_COLLECTION_USER_MEMORY=zhipath_user_memory_v1
QDRANT_COLLECTION_CONV_SUMMARY=zhipath_conversation_summary_v1
EMBEDDING_DIMENSION=1536

# ---------- MinIO / 对象存储 ----------
OBJECT_STORAGE_ENDPOINT=localhost:9000
OBJECT_STORAGE_BUCKET=zhipath-ai
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_USE_SSL=false

# ---------- 服务端口 ----------
API_GATEWAY_PORT=8080
AI_AGENT_SERVICE_URL=http://localhost:8001
OCR_SERVICE_URL=http://localhost:8002
WORKER_SERVICE_URL=http://localhost:8003

# ---------- 模型 Provider ----------
PRIMARY_MODEL=deepseek:deepseek-chat
FALLBACK_MODEL=openai:gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-large

DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- 微信 ----------
WECHAT_MINIAPP_APPID=
WECHAT_MINIAPP_SECRET=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_NOTIFY_URL=

# ---------- 内部服务间鉴权 ----------
INTERNAL_SERVICE_TOKEN=dev-internal-service-token

# ---------- n8n ----------
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ---------- 可观测性 ----------
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
